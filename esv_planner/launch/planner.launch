<launch>
  <arg name="strict_rebuild_case" default="" />
  <node name="esv_planner" pkg="esv_planner" type="esv_planner_node" output="screen">
    <rosparam file="$(find esv_planner)/config/planner.yaml" command="load" />
    <param name="strict_rebuild_case" value="$(arg strict_rebuild_case)" />
  </node>
</launch>
