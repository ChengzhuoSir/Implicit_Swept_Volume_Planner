<launch>
  <arg name="map_file" default="$(find esv_planner)/maps/map_clean_nav.yaml" />

  <node name="map_server"
        pkg="map_server"
        type="map_server"
        args="$(arg map_file)"
        required="true" />

  <node name="esv_planner"
        pkg="esv_planner"
        type="esv_planner_node"
        output="screen"
        required="true">
    <rosparam file="$(find esv_planner)/config/planner.yaml" command="load" />
    <rosparam file="$(find esv_planner)/test/strict_svsdf_demo_params.yaml" command="load" />
    <param name="use_start_goal_params" value="true" />
  </node>

  <test test-name="strict_svsdf_demo_smoke"
        pkg="esv_planner"
        type="paper_pipeline_smoke.py"
        time-limit="60">
    <param name="timeout" value="25.0" />
    <param name="trajectory_topic" value="/esv_planner/trajectory" />
    <param name="stats_topic" value="/esv_planner/planning_stats" />
  </test>
</launch>
